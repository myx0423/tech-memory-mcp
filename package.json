{
  "name": "tech-memory-mcp",
  "version": "0.1.0",
  "description": "中文优先的 AI Agent 技术知识记忆 MCP Server",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "tech-memory-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "src/prompts/"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const p=require('path');const src=fs.readdirSync('src/prompts');for(const f of src){const d=p.join('dist/prompts');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p.join('src/prompts',f),p.join(d,f))}\"",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "memory",
    "knowledge-graph",
    "vector-search",
    "chinese",
    "embeddings",
    "claude-code",
    "agent-memory",
    "node-sqlite"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/myx0423/tech-memory-mcp"
  },
  "license": "MIT",
  "engines": {
    "node": ">=23.5.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ulidx": "^2.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
