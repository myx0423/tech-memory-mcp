{
  "name": "tech-memory-mcp",
  "version": "0.1.0",
  "description": "中文优先的 AI Agent 技术知识记忆 MCP Server",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "tech-memory-mcp": "./dist/index.js",
    "tech-memory-cli": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "src/prompts/"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const p=require('path');const src=fs.readdirSync('src/prompts');for(const f of src){const d=p.join('dist/prompts');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p.join('src/prompts',f),p.join(d,f))}\"",
    "start": "node dist/index.js",
    "export": "node dist/cli.js export",
    "import": "node dist/cli.js import",
    "backup": "node dist/cli.js backup",
    "test": "node --test --import tsx test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "memory",
    "knowledge-graph",
    "vector-search",
    "chinese",
    "embeddings",
    "claude-code",
    "agent-memory",
    "node-sqlite"
  ],
  "author": "myx0423",
  "license": "MIT",
  "homepage": "https://github.com/myx0423/tech-memory-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/myx0423/tech-memory-mcp"
  },
  "bugs": {
    "url": "https://github.com/myx0423/tech-memory-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "ulidx": "^2.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  }
}
